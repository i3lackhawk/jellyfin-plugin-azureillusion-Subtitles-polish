      - name: Update Jellyfin manifest
        run: |
          set -euo pipefail

          MANIFEST_FILE="${GITHUB_WORKSPACE}/manifest.json"

          if [ ! -f "${MANIFEST_FILE}" ]; then
            echo "[]" > "${MANIFEST_FILE}"
          fi

          PLUGIN_URL="https://github.com/${{ github.repository }}/releases/download/${RELEASE_TAG}/${ZIP_NAME}"

          echo "Adres paczki:"
          echo "${PLUGIN_URL}"

          python -m jprm repo add \
            --plugin-url "${PLUGIN_URL}" \
            "${GITHUB_WORKSPACE}" \
            "${ZIP_FILE}"
